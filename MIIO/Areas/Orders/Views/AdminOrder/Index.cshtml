
<partial name="_Notifications" />

<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2>Lista de Órdenes (Pedidos)</h2>
        </div>

        <div class="col-6 text-end">
            <a asp-controller="AdminOrder" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nueva Orden
            </a>
        </div>
    </div>

    <table class="table table-striped table-bordered" id="tblData">
        <thead>
            <tr>
                <th>ID</th>
                <th>ID Usuario</th>
                <th>Descripción</th>
                <th>Monto Total</th>
                <th>Fecha</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
    </table>
</div>

<script src="~/js/order.js"></script>
