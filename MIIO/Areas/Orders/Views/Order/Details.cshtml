@model MIIO.Models.Order
@{
    var customer = ViewData["Customer"] as MIIO.Models.ApplicationUser;

    string customerName = customer != null ? $"{customer.Name} {customer.LastName}" : "Cliente Desconocido";
    string customerEmail = customer?.Email ?? "N/A";
    string shippingAddress = customer?.Address ?? "No Proporcionada";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12 text-center mb-4">
            <h4 class="text-primary">Detalles del Pedido</h4>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Datos del Pedido</h5>
                </div>
                <div class="card-body">
                    <p><strong>Estado:</strong> <span class="badge bg-primary">@Model.State</span></p>
                    <p><strong>Fecha:</strong> @Model.Date.ToString("dd/MM/yyyy HH:mm")</p>
                    <p><strong>Descripción:</strong> @Model.Description</p>
                    <p><strong>Total:</strong> ₡@Model.TotalAmount.ToString("N0")</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Cliente y Envío</h5>
                </div>
                <div class="card-body">
                    <p><strong>Nombre del Cliente:</strong> @customerName</p>
                    <p><strong>Email:</strong> @customerEmail</p>
                    <hr />
                    <h6>📍 Dirección de Envío</h6>
                    <p>@shippingAddress</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12 text-end">
            <a href="/Orders/Order" class="btn btn-secondary">Cerrar</a>
        </div>
    </div>
</div>