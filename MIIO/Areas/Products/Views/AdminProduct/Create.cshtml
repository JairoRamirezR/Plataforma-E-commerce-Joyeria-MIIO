@model MIIO.Models.Product

@{
    ViewData["Title"] = "Crear Nuevo Producto";
}

<div class="main-content">
    <section class="edit-product-section">
        <h1 class="page-title">Crear Producto</h1>
        <p class="page-subtitle">Ingresa la información del nuevo producto</p>

        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="card basic-info">
                <h2 class="card-title">Información Básica</h2>

                <div class="form-group">
                    <label asp-for="Name">Nombre del Producto</label>
                    <input asp-for="Name" placeholder="Nombre del Producto" class="input-full" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group-half">
                        <label asp-for="Price">Precio (CRC)</label>
                        <input asp-for="Price" type="number" class="input-half" value="0" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    <div class="form-group-half">
                        <label asp-for="Category">Categoría</label>
                        <input asp-for="Category" class="input-half" placeholder="Anillo, Collar, etc." />
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="card product-details">
                <h2 class="card-title">Detalles del Producto</h2>

                <div class="details-grid">
                    <div class="form-group-half">
                        <label asp-for="Material">Material</label>
                        <input asp-for="Material" class="input-half" placeholder="Plata 925, Oro, etc." />
                        <span asp-validation-for="Material" class="text-danger"></span>
                    </div>
                    <div class="form-group-half">
                        <label asp-for="Offer">Oferta (Sí/No)</label>
                        <input asp-for="Offer" type="checkbox" />
                        <span asp-validation-for="Offer" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group full-description-group">
                    <label>Descripción Completa</label>
                    <textarea asp-for="Description" class="full-description-textarea" placeholder="Descripción detallada del producto"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="card product-images">
                <h2 class="card-title">Imágenes del Producto</h2>

                <div class="image-upload-area">
                    <input type="file" name="file" class="d-none" id="file-upload-input" accept="image/*" />

                    <div class="image-list-container">

                        <div id="selected-image-box" class="image-box" style="display: none;">
                            <span id="selected-image-filename" class="image-filename"></span>
                            <i id="remove-image-icon" class="fas fa-times-circle remove-icon"></i>
                        </div>

                        <div class="image-box upload-placeholder" onclick="document.getElementById('file-upload-input').click()" id="add-image-box">
                            <span class="upload-icon">↑</span>
                            <span>Agregar</span>
                        </div>
                    </div>
                </div>
                <p class="image-upload-note">La imagen seleccionada será la principal.</p>
            </div>

            <div class="action-buttons">
                <a asp-action="Index" class="btn btn-cancel">Cancelar</a>
                <button type="submit" class="btn btn-save">Crear Producto</button>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const fileInput = document.getElementById('file-upload-input');
            const selectedImageBox = document.getElementById('selected-image-box');
            const fileNameSpan = document.getElementById('selected-image-filename');
            const removeIcon = document.getElementById('remove-image-icon');
            const addImageBox = document.getElementById('add-image-box');

            function updateImageDisplay() {
                if (fileInput.files.length > 0) {
                    const fileName = fileInput.files[0].name;
                    fileNameSpan.textContent = fileName;

                    selectedImageBox.style.display = 'flex';
                    addImageBox.style.display = 'none';

                    selectedImageBox.style.backgroundImage = `url(data:image/svg+xml;base64,)`;
                    selectedImageBox.style.backgroundRepeat = 'no-repeat';
                    selectedImageBox.style.backgroundPosition = 'center 20px';
                    selectedImageBox.style.backgroundSize = '40px 40px';

                } else {
                    selectedImageBox.style.display = 'none';
                    addImageBox.style.display = 'flex';
                    fileNameSpan.textContent = '';
                }
            }

            fileInput.addEventListener('change', updateImageDisplay);

            removeIcon.addEventListener('click', function(e) {
                e.stopPropagation(); 
                fileInput.value = ''; 
                updateImageDisplay(); 
            });

            updateImageDisplay();
        });
    </script>

    <style>
        .image-list-container {
            display: flex;
            gap: 20px;
            margin-bottom: 10px;
        }

        .image-box {
            width: 150px;
            height: 150px;
            border: 1px solid #ccc;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative; 
            box-sizing: border-box;
            background-color: #f9f9f9;
            text-align: center;
        }

            .image-box.upload-placeholder {
                border: 2px dashed #007bff;
                color: #007bff;
            }

                .image-box.upload-placeholder:hover {
                    background-color: #e9f5ff;
                }

        .upload-icon {
            font-size: 30px;
            line-height: 1;
        }

        .image-filename {
            padding: 5px;
            font-size: 12px;
            word-break: break-all;
            color: #333;
            margin-top: 50px; 
        }

        .remove-icon {
            position: absolute;
            top: 5px;
            right: 5px;
            color: #dc3545;
            cursor: pointer;
            font-size: 18px;
            z-index: 10;
        }
    </style>
}