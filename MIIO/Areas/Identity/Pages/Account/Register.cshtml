@page
@model RegisterModel
@{
    ViewData["Title"] = "Registrarse";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 100vh;">
    <div class="card shadow p-4" style="width: 420px; border-radius: 12px;">

        <h3 class="text-center mb-4">Registrarse</h3>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- NOMBRE -->
            <input asp-for="Input.Name" class="form-control mb-3 input-custom" placeholder="Nombre *" />
            <span asp-validation-for="Input.Name" class="text-danger"></span>

            <!-- APELLIDO -->
            <input asp-for="Input.LastName" class="form-control mb-3 input-custom" placeholder="Apellido *" />
            <span asp-validation-for="Input.LastName" class="text-danger"></span>

            <!-- DIRECCIÓN -->
            <input asp-for="Input.Address" class="form-control mb-3 input-custom" placeholder="Dirección *" />
            <span asp-validation-for="Input.Address" class="text-danger"></span>

            <!-- FECHA DE NACIMIENTO -->
            <input asp-for="Input.BirthDay" type="date" class="form-control mb-3 input-custom" />
            <span asp-validation-for="Input.BirthDay" class="text-danger"></span>

            <!-- EMAIL -->
            <input asp-for="Input.Email"
                   class="form-control mb-3 input-custom"
                   placeholder="Correo electrónico *" />
            <span asp-validation-for="Input.Email" class="text-danger"></span>

            <!-- PASSWORD -->
            <input asp-for="Input.Password"
                   class="form-control mb-3 input-custom"
                   placeholder="Contraseña *" />
            <span asp-validation-for="Input.Password" class="text-danger"></span>

            <!-- CONFIRM PASSWORD -->
            <input asp-for="Input.ConfirmPassword"
                   class="form-control mb-4 input-custom"
                   placeholder="Confirmar contraseña *" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>

            <button type="submit" class="btn w-100 text-white py-2"
                    style="background-color: black; border-radius: 6px;">
                Registrarse
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .input-custom {
        height: 50px;
        border-radius: 8px;
        background-color: #f6f6f6;
        border: 1px solid #ddd;
        padding-left: 15px;
    }

        .input-custom:focus {
            border-color: black;
            box-shadow: none;
        }
</style>
