@page
@model LoginModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<style>
    body {
        background-color: #ffffff;
        font-family: 'Segoe UI', sans-serif;
        color: #000000;
    }

    .login-wrapper {
        max-width: 400px;
        margin: 80px auto;
        padding: 20px;
    }

        .login-wrapper h1 {
            font-size: 1.8rem;
            font-weight: 600;
            text-align: center;
            margin-bottom: 10px;
        }

        .login-wrapper h2 {
            font-size: 1.2rem;
            font-weight: 400;
            text-align: center;
            margin-bottom: 30px;
            color: #555;
        }

    .form-floating label {
        color: #333;
    }

    .btn-black {
        background-color: #000;
        color: #fff;
        border: none;
        width: 100%;
        padding: 10px;
        font-size: 1rem;
    }

        .btn-black:hover {
            background-color: #333;
        }

    .extra-links {
        margin-top: 20px;
        text-align: center;
        font-size: 0.95rem;
    }

        .extra-links a {
            display: block;
            margin: 5px 0;
            color: #000;
            text-decoration: underline;
        }

    .external-login {
        margin-top: 40px;
        text-align: center;
    }

        .external-login button {
            margin: 5px;
            background-color: #000;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
        }

            .external-login button:hover {
                background-color: #333;
            }
</style>

<div class="login-wrapper">
    <h1>@ViewData["Title"]</h1>
    <h2>Reconoceremos si ya tienes una cuenta</h2>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <!-- CORREO -->
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="correo@ejemplo.com" />
            <label asp-for="Input.Email">Correo electrónico</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <!-- CONTRASEÑA -->
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="contraseña" />
            <label asp-for="Input.Password">Contraseña</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <!-- RECORDAR -->
        <div class="form-check mb-3">
            <input class="form-check-input" asp-for="Input.RememberMe" />
            <label class="form-check-label" asp-for="Input.RememberMe">
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
        </div>

        <!-- BOTÓN LOGIN -->
        <button id="login-submit" type="submit" class="btn btn-black">Continuar</button>

        <!-- ENLACES EXTRA -->
        <div class="extra-links">
            <a asp-page="./ForgotPassword">¿Olvidaste tu contraseña?</a>
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Registrarse</a>
            <a asp-page="./ResendEmailConfirmation">Reenviar confirmación de correo</a>
        </div>
    </form>

    <!-- LOGIN EXTERNO -->
    <div class="external-login">
        <h5>O usa otro servicio</h5>
        @{
            if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" name="provider" value="@provider.Name">
                            @provider.DisplayName
                        </button>
                    }
                </form>
            }
        }
    </div>
</div>
