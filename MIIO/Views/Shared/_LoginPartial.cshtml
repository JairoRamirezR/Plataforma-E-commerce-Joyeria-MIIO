@using Microsoft.AspNetCore.Identity
@using MIIO.Models
@using MIIO.Utilities

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        // 1. Reemplazamos los dos <li> originales por un solo <li> dropdown
        <li class="nav-item dropdown">

            @* Botón que activa el dropdown (con la flecha) *@
            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdownUser" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                Hello @UserManager.GetUserName(User)!
            </a>

            @* 2. Contenedor del menú desplegable *@
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdownUser">

                @* 3. Opción para Administrar Productos (SOLO para Admin) *@
                @if (User.IsInRole(MIIO.Utilities.StaticValues.Role_Admin))
                {
                    <li>
                        @* Enlace a: /Products/AdminProduct *@
                        <a class="dropdown-item" asp-area="" asp-controller="Products" asp-action="AdminProduct">
                            Administrar Productos
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                }

                @* 4. Opción de Perfil/Manage (opcional, pero útil) *@
                <li>
                    <a class="dropdown-item" id="manage" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                        Mi Perfil
                    </a>
                </li>

                @* 5. Formulario de Logout (Cerrar Sesión) *@
                <li>
                    <form id="logoutForm" class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button id="logout" type="submit" class="dropdown-item">
                            Cerrar Sesión
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        // Código para usuarios NO logueados se mantiene igual
        <li class="nav-item">
            <a class="nav-link text-dark" id="register" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" id="login" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>